# Configuración para Ambiente de Producción
# IMPORTANTE: Cambiar todos los valores antes de desplegar

# ============ BASE DE DATOS ============
# Para PRODUCCIÓN: Usar PostgreSQL en lugar de SQLite
DATABASE_URL=postgresql://labeling_user:strong_password_here@postgres:5432/labeling_db
# DATABASE_URL=sqlite:///labeling_app.db  # Solo para desarrollo

# ============ SEGURIDAD ============
# Generar claves fuertes: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=generate_strong_key_with_32_chars_minimum
SECRET_KEY=generate_another_strong_key_32_chars

# ============ SERVIDOR ============
FLASK_ENV=production
HOST=0.0.0.0
PORT=8080
WORKERS=4
DEBUG=False

# ============ LOGGING ============
LOG_LEVEL=INFO
ACCESS_LOG=-
ERROR_LOG=-

# ============ NOTIFICACIONES (OPT) ============
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ============ BACKUPS ============
BACKUP_DIR=data/backups
MAX_BACKUPS=30